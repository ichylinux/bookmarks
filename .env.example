# Copy this file to .env and fill in the values.
# .env is gitignored and must NEVER be committed to version control.
#
# Generate SECRET_KEY_BASE with: bin/rails secret

SECRET_KEY_BASE=

# Database
MYSQL_USERNAME=
MYSQL_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_API_KEY=

# Twitter OAuth
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Production email (AWS SES)
AWS_ADDRESS=
AWS_DOMAIN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# App
APP_HOST=localhost
