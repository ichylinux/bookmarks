<%= form_with model: @todo, html: {class: 'todo'} do |f| %>
  <table>
    <tr>
      <td><%= f.select :priority, Todo.priority_options %></td>
      <td><%= f.text_field :title %></td>
      <td>
        <% if @todo.new_record? %>
          <%= f.submit t('.create'), onclick: 'todos.create_todo(this); return false;' %>
        <% else %>
          <%= f.submit t('.update'), onclick: 'todos.update_todo(this); return false;' %>
        <% end %>
      </td>
    </tr>
  </table>
<% end %>
