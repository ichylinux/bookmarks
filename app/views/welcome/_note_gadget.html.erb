<section class="note-gadget">
  <h2><%= t('.title') %></h2>
  <%= form_with model: @note, url: notes_path, local: true, html: { class: 'note-gadget-form' } do |f| %>
    <%= f.label :body, t('.body_label') %>
    <%= f.text_area :body, rows: 4 %>
    <%= f.submit t('.submit') %>
  <% end %>
  <% if @notes.empty? %>
    <p class="note-empty"><%= t('.empty') %></p>
  <% else %>
    <div class="note-list">
      <% @notes.each do |note| %>
        <div class="note-item">
          <div class="note-body"><%= note.body %></div>
          <div class="note-timestamp"><%= note.created_at.strftime('%Y-%m-%d %H:%M') %></div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
