<section class="note-gadget">
  <h2><%= t('.title') %></h2>
  <div class="note-gadget-composer">
    <%= form_with model: @note, url: notes_path, local: true, html: { class: 'note-gadget-form' } do |f| %>
      <%= f.text_area :body, rows: 4, aria: { label: t('.body_label') } %>
      <%= f.submit t('.submit') %>
    <% end %>
  </div>
  <% if @notes.empty? %>
    <p class="note-empty"><%= t('.empty') %></p>
  <% else %>
    <div class="note-list">
      <% @notes.each do |note| %>
        <div class="note-item">
          <%= form_with model: note, local: true, html: { class: 'note-item-edit-form' } do |f| %>
            <%= f.text_area :body, rows: 3 %>
            <%= f.submit t('.update') %>
          <% end %>
          <%= button_to t('.delete'),
                        note_path(note),
                        method: :delete,
                        form: { class: 'note-item-delete-form' } %>
          <div class="note-timestamp"><%= note.created_at.strftime('%Y-%m-%d %H:%M') %></div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
