<section class="note-gadget"
         data-note-action-update-label="<%= t('.update') %>"
         data-note-action-delete-label="<%= t('.delete') %>"
         data-note-action-cancel-label="<%= t('.cancel') %>">
  <div class="note-gadget-composer">
    <%= form_with model: @note, url: notes_path, local: true, html: { class: 'note-gadget-form' } do |f| %>
      <%= f.text_area :body, rows: 4, aria: { label: t('.body_label') } %>
      <%= f.submit t('.submit') %>
    <% end %>
  </div>
  <% if @notes.empty? %>
    <p class="note-empty"><%= t('.empty') %></p>
  <% else %>
    <div class="note-list">
      <% @notes.each do |note| %>
        <% created_time = note.created_at.strftime('%Y-%m-%d %H:%M') %>
        <% updated_time = note.updated_at.strftime('%Y-%m-%d %H:%M') %>
        <% edited = note.updated_at.to_i != note.created_at.to_i %>
        <div class="note-item">
          <div class="note-item-display" tabindex="0">
            <div class="note-body"><%= note.body %></div>
            <div class="note-timestamp">
              <span class="note-created-at"><%= created_time %></span>
              <% if edited %>
                <span class="note-edited-badge"
                      title="<%= t('.edited_tooltip', time: updated_time) %>"
                      aria-label="<%= t('.edited_tooltip', time: updated_time) %>"><%= t('.edited_badge') %></span>
              <% end %>
            </div>
          </div>
          <%= form_with model: note, local: true, html: { class: 'note-item-edit-form', hidden: true } do |f| %>
            <%= f.text_area :body, rows: 3 %>
            <%= f.submit t('.update') %>
          <% end %>
          <button type="button" class="note-item-cancel-button" hidden><%= t('.cancel') %></button>
          <%= button_to t('.delete'),
                        note_path(note),
                        method: :delete,
                        form: { class: 'note-item-delete-form', hidden: true } %>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
