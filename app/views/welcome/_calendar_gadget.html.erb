<div id="<%= gadget.gadget_id %>" class="gadget">
  <div>
    <div class="title"><%= gadget.title %></div>
    <div style="line-height: 30em;">
      <script>
        $(document).ready(function() {
          $.get('<%= get_gadget_calendars_path(display_date: gadget.display_date) %>', {format: 'html'}, function(html) {
            $('#<%= gadget.gadget_id %>').find('div').last().replaceWith(html);
          });
        });
      </script>
      <span><%= t('welcome.calendar_gadget.loading') %></span>
    </div>
  </div>
</div>
